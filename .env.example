NEXT_PUBLIC_SITE_URL=https://vokdev.com
NEXT_PUBLIC_SITE_NAME=VokDev

# Better Auth (https://www.better-auth.com/docs/installation)
BETTER_AUTH_SECRET=            # openssl rand -base64 32 (min 32 chars; required in production)
BETTER_AUTH_URL=https://vokdev.com
# Optional: comma-separated extra origins (previews, staging)
# BETTER_AUTH_TRUSTED_ORIGINS=https://staging.vokdev.com

# Auth database: Turso/libsql URL (production), or local file path (development default: .data/auth.sqlite)
# AUTH_DATABASE_URL=libsql://...
# AUTH_DATABASE_PATH=.data/auth.sqlite

# Comma-separated emails that may access /cms/admin/* (in addition to users with role=admin in the auth DB)
# CMS_ADMIN_EMAILS=you@example.com
# CMS_DISABLE_SIGNUP=true
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_DATABASE_ID=...   # D1 database UUID from dashboard
CLOUDFLARE_D1_TOKEN=...      # API token with D1 edit (keep secret) — Drizzle Kit `d1-http`

# Wrangler (`pnpm db:migrate:remote`, deploy): Account API token or “Edit Cloudflare Workers”
CLOUDFLARE_API_TOKEN=