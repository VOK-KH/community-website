# Local development (`pnpm dev`, NODE_ENV=development).
# Copy to `.env.development` and fill in. This file is gitignored when you use real secrets.

# --- Next.js (exposed to the browser only if prefixed with NEXT_PUBLIC_) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=VokDev

BETTER_AUTH_SECRET=local-dev-secret-change-me-32chars!!
BETTER_AUTH_URL=http://localhost:3000
# AUTH_DATABASE_PATH=.data/auth.sqlite
# CMS_ADMIN_EMAILS=you@example.com

# --- Drizzle Kit / Cloudflare (optional here if already in `.env`) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Remote D1 migrations / Wrangler (not the same as CLOUDFLARE_D1_TOKEN unless you reuse one token)
CLOUDFLARE_API_TOKEN=
