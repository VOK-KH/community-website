NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=VokDev

BETTER_AUTH_SECRET=local-dev-secret-change-me-32chars!!
BETTER_AUTH_URL=http://localhost:3000
# Passkeys: rpID is localhost when using the URL above (Chrome WebAuthn devtools supported).
# Auth DB: D1 (if set, auth uses HTTP API — good parity with production) or local file
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DATABASE_ID=
# CLOUDFLARE_D1_TOKEN=
# AUTH_DATABASE_PATH=.data/auth.sqlite
# CMS_ADMIN_EMAILS=you@example.com

# OAuth (optional — Google/GitHub on /joint; redirect URIs e.g. http://localhost:3000/api/auth/callback/google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Drizzle Kit / Cloudflare (optional here if already in `.env`) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=

# Remote D1 migrations / Wrangler (not the same as CLOUDFLARE_D1_TOKEN unless you reuse one token)
CLOUDFLARE_API_TOKEN=
